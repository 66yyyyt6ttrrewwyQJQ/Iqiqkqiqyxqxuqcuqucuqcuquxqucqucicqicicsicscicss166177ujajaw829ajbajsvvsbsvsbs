function VisualsModule:Initialize()
	self.Camera = self.Workspace.CurrentCamera
	self.FX_ROOT = self.ReplicatedStorage:WaitForChild("FXTemplates")
	local playerGui = self.player:FindFirstChildOfClass("PlayerGui")
	if playerGui then
		local sg = playerGui:FindFirstChild("ScreenGui")
		if sg then
			self.HITSOUND_STORAGE = sg:FindFirstChild("storage")
		end
	end

	self.ORIGINAL_EFFECTS = {
		Atmosphere = self:SnapshotFirstEffect("Atmosphere"),
		BloomEffect = self:SnapshotFirstEffect("BloomEffect"),
		ColorCorrectionEffect = self:SnapshotFirstEffect("ColorCorrectionEffect"),
	}

	self:CreateHitlogUI()
	self:CreateOffscreenArrows()
	self:CreateKillImageGUI()
	self:CreateHitMarkerUI()
	self:SetupBacktrackGhost()
	self:SetupKillFXListener()
	self:SetupPlayerEffects()
end

function VisualsModule:CreateHitlogUI()
	local screenGui = Instance.new("ScreenGui")
	screenGui.Name = "Hitlogs"
	screenGui.ResetOnSpawn = false
	screenGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
	screenGui.Parent = self.guiParent

	local container = Instance.new("Frame")
	container.Name = "HitlogList"
	container.Active = false
	container.Selectable = false
	container.Size = UDim2.new(0, 300, 0, 200)
	container.Position = UDim2.new(0.5, -150, 0.55, 20)
	container.AnchorPoint = Vector2.new(0, 0)
	container.BackgroundTransparency = 1
	container.BorderSizePixel = 0
	container.Parent = screenGui

	local listLayout = Instance.new("UIListLayout")
	listLayout.SortOrder = Enum.SortOrder.LayoutOrder
	listLayout.Padding = UDim.new(0, 2)
	listLayout.VerticalAlignment = Enum.VerticalAlignment.Top
	listLayout.HorizontalAlignment = Enum.HorizontalAlignment.Center
	listLayout.Parent = container

	self.hitlogContainer = container
	self.hitlogOrder = 0
end

function VisualsModule:SpawnWings()
	self:DestroyWings()
	local char = self.player.Character
	if not char or not char:FindFirstChild("HumanoidRootPart") then return end

	local hrp = char.HumanoidRootPart

	local wingModel = Instance.new("Model")
	wingModel.Name = "EnhancedAngelWings"

	local leftWing = Instance.new("Part")
	leftWing.Name = "LeftWing"
	leftWing.Size = Vector3.new(0.2, 4, 6)
	leftWing.Transparency = 0.1
	leftWing.Material = Enum.Material.ForceField
	leftWing.Color = self.WINGS_COLOR
	leftWing.CanCollide = false
	leftWing.Anchored = false
	leftWing.Parent = wingModel

	local rightWing = leftWing:Clone()
	rightWing.Name = "RightWing"
	rightWing.Parent = wingModel

	local weldLeft = Instance.new("WeldConstraint")
	weldLeft.Part0 = hrp
	weldLeft.Part1 = leftWing
	weldLeft.Parent = leftWing

	local weldRight = weldLeft:Clone()
	weldRight.Part1 = rightWing
	weldRight.Parent = rightWing

	for i = 1, 12 do
		local feather = Instance.new("Part")
		feather.Size = Vector3.new(0.15, 0.8 + math.random(), 2.5)
		feather.Transparency = 0.3
		feather.Material = Enum.Material.Neon
		feather.Color = self.WINGS_COLOR:Lerp(Color3.new(1,1,1), 0.4)
		feather.CanCollide = false
		feather.Parent = wingModel

		local fw = Instance.new("WeldConstraint")
		fw.Part0 = leftWing
		fw.Part1 = feather
		fw.Parent = feather

		feather.CFrame = leftWing.CFrame * CFrame.new(-1.2, -2 + i*0.6, 0) * CFrame.Angles(0, 0, math.rad(30 + i*5))
	end

	for i = 1, 12 do
		local feather = Instance.new("Part")
		feather.Size = Vector3.new(0.15, 0.8 + math.random(), 2.5)
		feather.Transparency = 0.3
		feather.Material = Enum.Material.Neon
		feather.Color = self.WINGS_COLOR:Lerp(Color3.new(1,1,1), 0.4)
		feather.CanCollide = false
		feather.Parent = wingModel

		local fw = Instance.new("WeldConstraint")
		fw.Part0 = rightWing
		fw.Part1 = feather
		fw.Parent = feather

		feather.CFrame = rightWing.CFrame * CFrame.new(1.2, -2 + i*0.6, 0) * CFrame.Angles(0, 0, math.rad(-30 - i*5))
	end

	local particles = Instance.new("ParticleEmitter")
	particles.Texture = "rbxassetid://243660364"
	particles.Color = ColorSequence.new(self.WINGS_COLOR)
	particles.LightEmission = 1
	particles.Size = NumberSequence.new({NumberSequenceKeypoint.new(0, 0.4), NumberSequenceKeypoint.new(1, 0)})
	particles.Transparency = NumberSequence.new({NumberSequenceKeypoint.new(0, 0), NumberSequenceKeypoint.new(1, 1)})
	particles.Lifetime = NumberRange.new(1.2, 2.5)
	particles.Rate = 80
	particles.Speed = NumberRange.new(2, 6)
	particles.SpreadAngle = Vector2.new(40, 40)
	particles.Parent = leftWing

	local particles2 = particles:Clone()
	particles2.Parent = rightWing

	local trailL = Instance.new("Trail")
	trailL.Color = ColorSequence.new(self.WINGS_COLOR)
	trailL.LightEmission = 1
	trailL.Transparency = NumberSequence.new({NumberSequenceKeypoint.new(0, 0.2), NumberSequenceKeypoint.new(1, 1)})
	trailL.Lifetime = 1.8
	trailL.Attachment0 = Instance.new("Attachment", leftWing)
	trailL.Attachment1 = Instance.new("Attachment", leftWing)
	trailL.Attachment1.Position = Vector3.new(0, 3, 0)
	trailL.Parent = leftWing

	local trailR = trailL:Clone()
	trailR.Parent = rightWing

	local glow = Instance.new("PointLight")
	glow.Color = self.WINGS_COLOR
	glow.Range = 25
	glow.Brightness = 3.5
	glow.Shadows = false
	glow.Parent = hrp

	self._wingData = {
		model = wingModel,
		allParts = {leftWing, rightWing},
		allTrails = {trailL, trailR},
		particles = particles,
		glow = glow
	}

	wingModel.Parent = char

	self._wingConn = self.RunService.Heartbeat:Connect(function(dt)
		if not char.Parent or not leftWing.Parent then
			self:DestroyWings()
			return
		end

		local sway = math.sin(tick() * 4) * 0.15
		leftWing.CFrame = hrp.CFrame * CFrame.new(-2, 0.5, -1) * CFrame.Angles(math.rad(15 + sway*20), math.rad(-35), math.rad(10))
		rightWing.CFrame = hrp.CFrame * CFrame.new(2, 0.5, -1) * CFrame.Angles(math.rad(15 - sway*20), math.rad(35), math.rad(-10))
	end)
end

function VisualsModule:DestroyWings()
	if self._wingConn then
		self._wingConn:Disconnect()
		self._wingConn = nil
	end
	if self._wingData and self._wingData.model then
		self._wingData.model:Destroy()
		self._wingData = nil
	end
end

local auraAssets = {
	starlight = "rbxassetid://134645216613107",
	heavenly = "rbxassetid://139300897520961",
	ribbon = "rbxassetid://132069507632161",
	sakura = "rbxassetid://81755778619404",
	angel = "rbxassetid://97658130917593",
	wind = "rbxassetid://80694081850877",
	flow = "rbxassetid://119913533725648",
	star = "rbxassetid://73754563740680"
}

function VisualsModule:SpawnAura(auraType)
	self:DestroyAura()
	if not auraType or not auraAssets[auraType] then return end

	local char = self.player.Character
	if not char or not char:FindFirstChild("HumanoidRootPart") then return end

	local hrp = char.HumanoidRootPart

	local auraFolder = Instance.new("Folder")
	auraFolder.Name = "JujuAura_" .. auraType

	local mainEffect = game:GetObjects(auraAssets[auraType])[1]:Clone()
	mainEffect.Parent = auraFolder

	local centerOrb = Instance.new("Part")
	centerOrb.Name = "AuraCore"
	centerOrb.Shape = Enum.PartType.Ball
	centerOrb.Size = Vector3.new(3, 3, 3)
	centerOrb.Material = Enum.Material.Neon
	centerOrb.Color = self.AURA_COLOR
	centerOrb.Transparency = 0.2
	centerOrb.CanCollide = false
	centerOrb.Anchored = false
	centerOrb.Parent = auraFolder

	local coreLight = Instance.new("PointLight")
	coreLight.Color = self.AURA_COLOR
	coreLight.Range = 40
	coreLight.Brightness = 7
	coreLight.Parent = centerOrb

	local coreTrail = Instance.new("Trail")
	coreTrail.Color = ColorSequence.new(self.AURA_COLOR)
	coreTrail.LightEmission = 1
	coreTrail.Lifetime = 1.4
	coreTrail.Parent = centerOrb

	for _, obj in ipairs(auraFolder:GetChildren()) do
		if obj:IsA("BasePart") then
			local weld = Instance.new("WeldConstraint")
			weld.Part0 = hrp
			weld.Part1 = obj
			weld.Parent = obj
		elseif obj:IsA("Model") then
			local mainPart = obj:FindFirstChildWhichIsA("BasePart")
			if mainPart then
				local weld = Instance.new("WeldConstraint")
				weld.Part0 = hrp
				weld.Part1 = mainPart
				weld.Parent = mainPart
			end
		end
	end

	self._auraConn = self.RunService.Heartbeat:Connect(function()
		if not char.Parent or not auraFolder.Parent then
			self:DestroyAura()
			return
		end

		local pulse = 1 + math.sin(tick() * 3.5) * 0.15
		centerOrb.Size = Vector3.new(3 * pulse, 3 * pulse, 3 * pulse)

		for _, obj in ipairs(auraFolder:GetChildren()) do
			if obj:IsA("BasePart") and obj ~= centerOrb then
				obj.CFrame = hrp.CFrame * CFrame.Angles(0, tick() * 2.2, 0)
			elseif obj:IsA("Model") then
				obj:PivotTo(hrp.CFrame * CFrame.Angles(0, tick() * 1.8, 0))
			end
		end
	end)

	self._auraData = {
		folder = auraFolder,
		core = centerOrb,
		type = auraType
	}

	auraFolder.Parent = char
end

function VisualsModule:DestroyAura()
	if self._auraConn then
		self._auraConn:Disconnect()
		self._auraConn = nil
	end
	if self._auraData and self._auraData.folder then
		self._auraData.folder:Destroy()
		self._auraData = nil
	end
end

function VisualsModule:SetWingsEnabled(value)
	self.WINGS_ENABLED = value
	if value then
		self:SpawnWings()
	else
		self:DestroyWings()
	end
end

function VisualsModule:SetWingsColor(value)
	self.WINGS_COLOR = value
	if self._wingData then
		for _, p in ipairs(self._wingData.allParts or {}) do
			if p and p.Parent then p.Color = value end
		end
		for _, trail in ipairs(self._wingData.allTrails or {}) do
			if trail then trail.Color = ColorSequence.new(value) end
		end
		if self._wingData.glow then self._wingData.glow.Color = value end
		if self._wingData.particles then
			self._wingData.particles.Color = ColorSequence.new(value)
		end
	end
end

function VisualsModule:SetAuraEnabled(value)
	self.AURA_ENABLED = value
	if value then
		local auraKeys = {}
		for k in pairs(auraAssets) do
			table.insert(auraKeys, k)
		end
		if #auraKeys > 0 then
			local randomIndex = math.random(1, #auraKeys)
			local chosen = auraKeys[randomIndex]
			self.currentAuraType = chosen
			self:SpawnAura(chosen)
		end
	else
		self:DestroyAura()
		self.currentAuraType = nil
	end
end

function VisualsModule:SetAuraColor(value)
	self.AURA_COLOR = value
	if self._auraData then
		local function recolor(obj)
			if obj:IsA("BasePart") then
				obj.Color = value
				local light = obj:FindFirstChildOfClass("PointLight")
				if light then light.Color = value end
			elseif obj:IsA("ParticleEmitter") or obj:IsA("Trail") then
				obj.Color = ColorSequence.new(value)
			end
		end
		for _, child in ipairs(self._auraData.folder:GetDescendants()) do
			recolor(child)
		end
	end
end

function VisualsModule:SetSpecificAura(auraType)
	if not auraAssets[auraType] then return end
	self.currentAuraType = auraType
	self:SpawnAura(auraType)
end

return VisualsModule
